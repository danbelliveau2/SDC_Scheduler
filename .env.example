PORT=4003

# ── MySQL ────────────────────────────────────────────────
# Dev sandbox on the production server (recommended for development):
MYSQL_HOST=SERVER-APP1
MYSQL_PORT=3306
MYSQL_USER=dan
MYSQL_PASSWORD=<ask Abhi>
MYSQL_DATABASE=sdc_scheduler_dev

# For a fully local MySQL instead, install MySQL 9 and use:
# MYSQL_HOST=localhost  MYSQL_USER=root  MYSQL_PASSWORD=...  MYSQL_DATABASE=sdc_scheduler

# ── Auth ─────────────────────────────────────────────────
AUTH_ENABLED=true
JWT_SECRET=change-me-any-long-random-string

# ── Email (optional, blank = disabled) ───────────────────
SMTP_HOST=

# ── Reliability: automated DB backups ────────────────────
# Nightly mysqldump at 02:00 ET, pruned after BACKUP_KEEP_DAYS. On Windows set
# MYSQLDUMP_PATH to the full mysqldump.exe path (it's usually not on PATH).
BACKUP_DIR=
BACKUP_KEEP_DAYS=14
MYSQLDUMP_PATH=

# ── Total ETO bridge (optional, blank = disabled) ────────
# Read-only connection to the Total ETO ERP (SQL Server). When set, the
# scheduler pulls vendor PO status into the Vendor PO Track page every 30 min
# (+ a "Sync from ETO" button) and serves /api/eto/* lookups.
# Join key: a scheduler project's Job # === the ETO ProjectID.
ETO_HOST=
ETO_DATABASE=SDC
ETO_PORT=1433
ETO_DOMAIN=stevendouglas
ETO_USER=
ETO_PASSWORD=

# ── MCP server (read-only database MCP, mcp/sdc-db-server.mjs) ──
# Required to start the MCP server (it exposes the DB over the network).
MCP_TOKEN=change-me-to-a-long-random-string
MCP_PORT=4100
MCP_HOST=0.0.0.0
