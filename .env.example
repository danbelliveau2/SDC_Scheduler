# SDC Scheduler — environment configuration.
# Copy to `.env` and fill in the values you need. Anything you leave commented
# stays disabled (auth off, no Azure sync, no email).

PORT=3000

# ─── Phase 3 — Auth ──────────────────────────────────────────────────────
# Set AUTH_ENABLED=true to require a JWT on every /api/* request. Run
#   node create-admin.js --email you@sdc.com --name "Your Name" --password "..."
# BEFORE flipping this on so you have a way to sign in.
AUTH_ENABLED=false
JWT_SECRET=change-this-to-a-random-64-char-string

# ─── Phase 6 — Azure SQL bidirectional sync (optional) ───────────────────
# Leave these empty to keep all data local in scheduler.db. When all four are
# set, server.js boots the azureSync watchers and pushes inserts/updates to
# the cloud (and pulls cloud changes back) every few seconds.
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=

# ─── Phase 7 — Email notifications (optional) ────────────────────────────
# Leave SMTP_HOST empty to disable emails (mentions still get logged to
# notification_log, just no SMTP delivery). Resend.com free tier works well.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SDC Scheduler <noreply@yourdomain.com>
